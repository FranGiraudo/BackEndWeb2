# SmartAuto Backend — Variables de Entorno
# Copiá este archivo como .env y completá tus valores

# ===================== BASE DE DATOS =====================
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:password@localhost:5432/smartauto_db"

# ===================== JWT =====================
JWT_SECRET="smartauto_super_secret_key_2024_cambiar_en_produccion"
JWT_EXPIRES_IN="7d"

# ===================== APP =====================
PORT=3000
# URL del frontend para CORS (Live Server)
FRONTEND_URL="http://localhost:5500"
# URL base para construir las URLs de las imágenes subidas
APP_URL="http://localhost:3000"

# ===================== CLOUDINARY =====================
# Obtenelos en: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"
